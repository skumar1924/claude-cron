{
  "name": "claude-cron",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "install-plugin": "./install.sh",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cron-parser": "^4.9.0",
    "cronstrue": "^2.50.0",
    "express": "^4.18.3",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.6",
    "@vitejs/plugin-react": "^4.3.1",
    "babel-jest": "^30.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "supertest": "^7.0.0",
    "vite": "^5.2.11"
  },
  "jest": {
    "projects": [
      {
        "displayName": "node",
        "testEnvironment": "node",
        "testMatch": [
          "**/tests/*.test.*"
        ]
      },
      {
        "displayName": "jsdom",
        "testEnvironment": "jsdom",
        "testMatch": [
          "**/tests/dashboard/**/*.test.*"
        ],
        "setupFilesAfterEnv": [
          "@testing-library/jest-dom"
        ],
        "transform": {
          "^.+\\.[jt]sx?$": ["babel-jest", { "configFile": false, "presets": [
            ["@babel/preset-env", { "targets": { "node": "current" } }],
            ["@babel/preset-react", { "runtime": "automatic" }]
          ]}]
        },
        "moduleNameMapper": {
          "\\.(css|less|scss)$": "<rootDir>/tests/__mocks__/fileMock.js"
        }
      }
    ]
  }
}
